---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/create.css";
---

<BaseLayout>
  <div class="create-wrapper">
    <div class="page-header">
      <h1 class="page-title">create</h1>
    </div>

    <div class="kind-toggle" role="tablist">
      <button type="button" class="kind-tab active" data-kind="ranking" role="tab" aria-selected="true">poll</button>
      <button type="button" class="kind-tab" data-kind="post" role="tab" aria-selected="false">post</button>
      <button type="button" class="kind-tab" data-kind="quote" role="tab" aria-selected="false">quote</button>
    </div>

    <form id="create-form">
      <div class="field">
        <label class="field-label" for="question" id="question-label">question</label>
        <input id="question" type="text" placeholder="what's your question?" required maxlength="200" />
        <span id="question-counter" class="body-counter" style="display:none"></span>
      </div>

      <div id="ranking-fields" class="field">
        <span class="field-label">options</span>
        <ul id="options-list" class="options-list">
          <li><input type="text" placeholder="option 1" maxlength="100" /><span class="option-counter body-counter" style="display:none"></span></li>
          <li><input type="text" placeholder="option 2" maxlength="100" /><span class="option-counter body-counter" style="display:none"></span></li>
        </ul>
        <div class="option-btns">
          <button type="button" id="add-option-btn" class="add-option-btn" aria-label="add option">+ add option</button>
          <button type="button" id="remove-option-btn" class="add-option-btn" aria-label="remove last option">− remove option</button>
        </div>
      </div>

      <div id="post-fields" class="field" hidden>
        <label class="field-label" for="body">body</label>
        <textarea id="body" placeholder="write your post..." rows="8"></textarea>
        <div class="post-field-footer">
          <button type="button" id="paste-btn" class="add-option-btn" aria-label="paste from clipboard">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="2" width="6" height="4" rx="1"/>
              <rect x="4" y="6" width="16" height="16" rx="2"/>
            </svg>
            paste
          </button>
          <span id="body-counter" class="body-counter" style="display:none"></span>
        </div>
      </div>

      <div id="quote-fields" class="field" hidden>
        <label class="field-label" for="quote-body">quote</label>
        <textarea id="quote-body" placeholder={`"quote"\n- speaker, date`} rows="8" maxlength="512"></textarea>
        <div class="post-field-footer">
          <button type="button" id="quote-paste-btn" class="add-option-btn" aria-label="paste from clipboard">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="2" width="6" height="4" rx="1"/>
              <rect x="4" y="6" width="16" height="16" rx="2"/>
            </svg>
            paste
          </button>
          <span id="quote-counter" class="body-counter" style="display:none"></span>
        </div>
      </div>

      <p id="create-error" class="create-error"></p>
      <button type="submit" class="btn">create</button>
    </form>
  </div>
</BaseLayout>

<script src="../scripts/create.ts"></script>
