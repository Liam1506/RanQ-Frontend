---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/admin.css";
import "../styles/start.css";
import "../styles/poll-detail.css";
---

<BaseLayout>
  <div class="page-header">
    <h1 class="page-title">users</h1>
  </div>
  <a href="/admin" class="back-btn">← admin</a>
  <div class="filters">
    <label for="user-search" class="sr-only">search users</label>
    <input id="user-search" type="text" placeholder="search username or id..." autocomplete="off" class="user-search-input" />
    <button id="filter-unverified" class="filter-toggle">unverified</button>
  </div>
  <p id="users-empty" class="feed-empty hidden">no users found.</p>
  <div id="users-list" class="feed"></div>
</BaseLayout>

<script src="../scripts/users.ts"></script>
