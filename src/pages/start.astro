---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/start.css";
import "../styles/poll-card.css";
---

<BaseLayout>
  <div class="page-header feed-header">
    <h1 class="page-title">feed</h1>
    <select class="filter-sort feed-sort-mobile">
      <option value="newest">newest</option>
      <option value="oldest">oldest</option>
      <option value="popular">most votes</option>
      <option value="discussed">most discussed</option>
    </select>
  </div>
  <div class="filters">
    <div class="type-tabs" role="tablist">
      <button type="button" class="type-tab active" data-type="all" role="tab">all</button>
      <button type="button" class="type-tab" data-type="ranking" role="tab">polls</button>
      <button type="button" class="type-tab" data-type="post" role="tab">posts</button>
      <button type="button" class="type-tab" data-type="quote" role="tab">quotes</button>
    </div>
    <button id="filter-unvoted" class="filter-toggle">not voted</button>
    <select id="filter-sort" class="filter-sort feed-sort-desktop">
      <option value="newest">newest</option>
      <option value="oldest">oldest</option>
      <option value="popular">most votes</option>
      <option value="discussed">most discussed</option>
    </select>
  </div>
  <button id="new-posts-banner" class="new-posts-banner" hidden>↑ new posts</button>
  <div id="feed" class="feed">
    <p class="feed-loading">loading...</p>
  </div>
</BaseLayout>

<script src="../scripts/feed.ts"></script>
