---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/start.css";
import "../styles/admin.css";
import "../styles/settings.css";
import "../styles/poll-card.css";
const isDev = import.meta.env.DEV;
---

<BaseLayout showNav={true}>
  <div class="settings-wrapper">
    <div class="page-header">
      <h1 class="page-title">admin panel</h1>
    </div>
    <section class="settings-section">
      <h2 class="settings-section-title">users</h2>
      <a href="/users" class="btn-secondary">manage users →</a>
    </section>
    <section class="settings-section">
      <h2 class="settings-section-title">site settings</h2>
        <div class="settings-row">
          <div class="settings-row-info">
            <label for="setting-auto-approve" class="settings-row-label">auto approve polls</label>
            <span class="settings-row-desc">skip approval queue for new submissions</span>
          </div>
          <div class="settings-row-control">
            <input type="checkbox" id="setting-auto-approve" />
          </div>
        </div>
        <div class="settings-row">
          <div class="settings-row-info">
            <label for="setting-allow-registration" class="settings-row-label">allow registration</label>
            <span class="settings-row-desc">let new users sign up</span>
          </div>
          <div class="settings-row-control">
            <input type="checkbox" id="setting-allow-registration" />
          </div>
        </div>
        <div class="settings-row">
          <div class="settings-row-info">
            <label for="setting-maintenance-mode" class="settings-row-label">maintenance mode</label>
            <span class="settings-row-desc">block all non-admin api access</span>
          </div>
          <div class="settings-row-control">
            <input type="checkbox" id="setting-maintenance-mode" />
          </div>
        </div>
        <div class="settings-row">
          <div class="settings-row-info">
            <label for="setting-max-options" class="settings-row-label">max options per poll</label>
            <span class="settings-row-desc">maximum number of options for ranking polls</span>
          </div>
          <div class="settings-row-control">
            <input type="number" id="setting-max-options" min="2" max="20" class="admin-setting-number" />
          </div>
        </div>
    </section>
    <section class="settings-section">
      <h2 class="settings-section-title">statistics</h2>
      <div class="admin-stats">
        <div class="admin-chart-info">
          <span class="settings-row-label">totals</span>
          <span class="settings-row-desc">overall counts across all users, polls, votes, likes and comments</span>
        </div>
        <canvas id="stats-totals" width="600" height="200"></canvas>
        <div class="admin-chart-info">
          <span class="settings-row-label">7-day activity</span>
          <span class="settings-row-desc">all events combined per day: Registrations, posts, comments, votes, likes</span>
        </div>
        <canvas id="stats-activity" width="600" height="200"></canvas>
      </div>
    </section>
    <section class="settings-section">
      <h2 class="settings-section-title">maintenance</h2>
        <div class="settings-row">
          <div class="settings-row-info">
            <span class="settings-row-label">run cleanup</span>
            <span class="settings-row-desc">delete unverified users, orphaned waitlist entries, and excess notifications</span>
          </div>
          <div class="settings-row-control">
            <button class="btn" id="cleanup-btn">run</button>
          </div>
        </div>
        <div class="settings-row settings-row--no-border">
          <p id="cleanup-result" class="admin-cleanup-result"></p>
        </div>
        {
          isDev && (
            <div class="settings-row">
              <div class="settings-row-info">
                <span class="settings-row-label">seed mock data</span>
                <span class="settings-row-desc">
                  dev only: create 10 users, polls, posts, quotes, votes, likes, comments
                </span>
              </div>
              <div class="settings-row-control">
                <button class="btn" id="seed-btn">seed</button>
              </div>
            </div>
          )
        }
        {
          isDev && (
            <div class="settings-row settings-row--no-border">
              <p id="seed-result" class="admin-cleanup-result" />
            </div>
          )
        }
    </section>
    <section class="settings-section">
      <h2 class="settings-section-title">polls for approval</h2>
      <div id="admin-box-polls" class="feed">
        <p class="feed-loading">loading...</p>
      </div>
    </section>
  </div>
</BaseLayout>

<script src="../scripts/admin.ts"></script>
{isDev && <script src="../scripts/seed.ts" />}
