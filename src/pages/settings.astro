---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/settings.css";
import "../styles/start.css";
import "../styles/poll-card.css";
---

<BaseLayout>
  <div class="page-header">
    <h1 class="page-title">settings</h1>
  </div>

  <div class="settings-wrapper">

    <section class="settings-section">
      <h2 class="settings-section-title">appearance</h2>
      <div class="settings-row">
        <span class="settings-row-label">theme</span>
        <div class="theme-toggle-group" role="tablist">
          <button type="button" class="theme-option" data-theme-choice="light" role="tab">light</button>
          <button type="button" class="theme-option" data-theme-choice="dark" role="tab">dark</button>
          <button type="button" class="theme-option" data-theme-choice="system" role="tab">system</button>
        </div>
      </div>
    </section>

    <section class="settings-section">
      <h2 class="settings-section-title">account</h2>
      <div class="settings-row">
        <span class="settings-row-label">username</span>
        <span id="info-username" class="settings-row-value">—</span>
      </div>
      <div class="settings-row">
        <span class="settings-row-label">email</span>
        <span id="info-email" class="settings-row-value">—</span>
      </div>
      <div class="settings-row settings-row--form">
        <span class="settings-row-label">change username</span>
        <div class="settings-inline-form">
          <input type="text" id="input-new-username" class="settings-input" placeholder="new username" autocomplete="off" />
          <button class="settings-action" id="btn-change-username">save</button>
        </div>
      </div>
      <p id="username-feedback" class="settings-feedback"></p>
      <div class="settings-row settings-row--form">
        <span class="settings-row-label">change password</span>
        <div class="settings-inline-form">
          <input type="password" id="input-current-password" class="settings-input" placeholder="current" />
          <input type="password" id="input-new-password" class="settings-input" placeholder="new" />
          <button class="settings-action" id="btn-change-password">save</button>
        </div>
      </div>
      <p id="password-feedback" class="settings-feedback"></p>
      <div class="settings-row settings-row--form">
        <span class="settings-row-label">delete account</span>
        <div class="settings-inline-form">
          <input type="text" id="input-delete-confirm" class="settings-input" placeholder='type "DELETE ACCOUNT"' autocomplete="off" />
          <button class="settings-action settings-action--red" id="btn-delete-account">delete</button>
        </div>
      </div>
      <p id="delete-feedback" class="settings-feedback"></p>
      <div class="settings-row settings-row-actions">
        <a class="settings-action settings-action-danger" href="/logout">log out</a>
      </div>
    </section>

    <section class="settings-section">
      <h2 class="settings-section-title">my posts</h2>
      <div class="filters">
        <div class="type-tabs" role="tablist">
          <button type="button" class="type-tab active" data-type="all" role="tab">all</button>
          <button type="button" class="type-tab" data-type="ranking" role="tab">rankings</button>
          <button type="button" class="type-tab" data-type="post" role="tab">thoughts</button>
        </div>
        <button id="filter-unapproved" class="filter-toggle">unapproved only</button>
      </div>
      <div id="settings-box-polls" class="feed">
        <p class="feed-loading">loading...</p>
      </div>
    </section>

  </div>
</BaseLayout>

<script src="../scripts/settings.ts"></script>
