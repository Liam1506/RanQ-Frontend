---
import "../styles/auth.css";
import Logo from "../components/Logo.astro";

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content="ranq — vote, rank and discuss with your friends." />
    <script is:inline>
      const t = localStorage.getItem("theme");
      if (t) document.documentElement.setAttribute("data-theme", t);
    </script>
  </head>
  <body>
    <Logo />
    <div class="auth-wrapper">
      <slot />
    </div>
    <button id="trailer-btn" aria-label="watch trailer">▶ trailer</button>
    <script>
      document.getElementById("trailer-btn")!.addEventListener("click", () => {
        window.open("/trailer.html", "_blank");
      });
    </script>
  </body>
</html>
