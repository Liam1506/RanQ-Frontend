---
import "../styles/auth.css";
import Logo from "../components/Logo.astro";

interface Props {
  title: string;
}
const { title } = Astro.props;
const apiBase = import.meta.env.PUBLIC_API_BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="api-base" content={apiBase} />
    <title>{title}</title>
    <meta name="description" content="ranq — vote, rank and discuss with your friends." />
    <script is:inline>
      const t = localStorage.getItem("theme");
      if (t) document.documentElement.setAttribute("data-theme", t);
    </script>
  </head>
  <body>
    <Logo />
    <div class="auth-wrapper">
      <slot />
    </div>
    <button id="trailer-btn" aria-label="watch trailer" style="display:none">▶ trailer</button>
    <script>
      import { API } from "../config/api";

      const btn = document.getElementById("trailer-btn") as HTMLButtonElement;
      const apiBase = document.querySelector('meta[name="api-base"]')?.getAttribute("content") || "";
      btn.addEventListener("click", () => {
        localStorage.setItem("apiBase", apiBase);
        window.open("/trailer", "_blank");
      });

      fetch(API.siteSettings.public)
        .then(r => r.json())
        .then(s => { if (s.show_trailer_button) btn.style.display = ""; })
        .catch(() => {});
    </script>
  </body>
</html>
