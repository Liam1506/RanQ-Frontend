---
import "../styles/auth.css";
import Logo from "../components/Logo.astro";

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content="ranq — vote, rank and discuss with your friends." />
    <script is:inline>
      const t = localStorage.getItem("theme");
      if (t) document.documentElement.setAttribute("data-theme", t);
    </script>
  </head>
  <body>
    <Logo />
    <div class="auth-wrapper">
      <slot />
    </div>
    <button id="trailer-btn" aria-label="watch trailer">▶ trailer</button>
    <div id="trailer-overlay" tabindex="-1">
      <iframe id="trailer-frame" src="" title="ranQ trailer"></iframe>
    </div>
    <script>
      const btn     = document.getElementById("trailer-btn")!;
      const overlay = document.getElementById("trailer-overlay")!;
      const frame   = document.getElementById("trailer-frame") as HTMLIFrameElement;

      btn.addEventListener("click", () => {
        frame.src = "/trailer.html";
        overlay.style.display = "block";
        overlay.requestFullscreen().catch(() => {});
      });

      // once iframe is loaded, tell it the current fullscreen state
      frame.addEventListener("load", () => {
        const msg = document.fullscreenElement ? "fullscreen-on" : "fullscreen-off";
        frame.contentWindow?.postMessage(msg, "*");
      });

      document.addEventListener("fullscreenchange", () => {
        if (document.fullscreenElement) {
          // keep focus on the parent page, not the iframe
          overlay.focus();
        } else {
          overlay.style.display = "none";
          frame.src = "";
        }
        // tell iframe about fullscreen state so it can update its button label
        const msg = document.fullscreenElement ? "fullscreen-on" : "fullscreen-off";
        frame.contentWindow?.postMessage(msg, "*");
      });

      // messages from iframe
      window.addEventListener("message", (e) => {
        if (e.data === "trailer-close") document.exitFullscreen();
        if (e.data === "trailer-toggle-fs") {
          if (!document.fullscreenElement) {
            overlay.requestFullscreen().catch(() => {});
          } else {
            document.exitFullscreen();
          }
        }
      });
    </script>
  </body>
</html>
