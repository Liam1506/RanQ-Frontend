---
import "../styles/baseLayout.css";
import Logo from "../components/Logo.astro";
import { Icon } from "astro-icon/components";

const { showNav = true } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, "") || "/";

const nav = [
  {
    href: "/start",
    label: "Home",
    outline: "heroicons:home",
    solid: "heroicons:home-solid",
  },
  {
    href: "/search",
    label: "Search",
    outline: "heroicons:magnifying-glass-circle",
    solid: "heroicons:magnifying-glass-circle-solid",
  },
  {
    href: "/create",
    label: "Create",
    outline: "heroicons:plus-circle",
    solid: "heroicons:plus-circle-solid",
  },
  {
    href: "/settings",
    label: "Settings",
    outline: "heroicons:cog-6-tooth",
    solid: "heroicons:cog-6-tooth-solid",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ranq</title>
    <meta
      name="description"
      content="ranq — vote, rank and discuss with your friends."
    />
    <script is:inline>
      const t = localStorage.getItem("theme");
      if (t) document.documentElement.setAttribute("data-theme", t);
    </script>
    <script>
      import { startNotificationPolling } from "../scripts/notifications";
      startNotificationPolling();
    </script>
  </head>
  <body>
    <header>
      <Logo />
    </header>
    <main>
      <div class="scroll-wrapper">
        <slot />
        <p class="copyright">
          © {new Date().getFullYear()} ranq · <a href="/impressum">impressum</a> ·
          <a href="/datenschutz">datenschutz</a>
        </p>
      </div>
    </main>
    {
      showNav && (
        <footer>
          <nav class="floating-nav">
            {nav.map(({ href, label, outline, solid }) => {
              const active = path === href;
              return (
                <a
                  href={href}
                  aria-label={label}
                  aria-current={active ? "page" : undefined}
                >
                  <Icon
                    name={active ? solid : outline}
                    size={24}
                    fill="currentColor"
                    is:inline
                  />
                </a>
              );
            })}
            <a
              href="/admin"
              aria-label="Admin"
              id="admin-nav-link"
              style="display:none"
              aria-current={path === "/admin" ? "page" : undefined}
            >
              <Icon
                name={
                  path === "/admin"
                    ? "heroicons:shield-check-solid"
                    : "heroicons:shield-check"
                }
                size={24}
                fill="currentColor"
                is:inline
              />
            </a>
          </nav>
        </footer>
      )
    }
    <script is:inline>
      const isAdmin = document.cookie
        .split("; ")
        .find((c) => c.startsWith("isAdmin="))
        ?.split("=")[1];
      if (isAdmin === "true") {
        document.getElementById("admin-nav-link").style.display = "";
      }
    </script>
  </body>
</html>
