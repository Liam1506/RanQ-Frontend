---
import "../styles/baseLayout.css";
import Logo from "../components/Logo.astro";
import HomeIcon from "../components/icons/HomeIcon.astro";
import SearchIcon from "../components/icons/SearchIcon.astro";
import AddIcon from "../components/icons/AddIcon.astro";
import SettingsIcon from "../components/icons/SettingsIcon.astro";
import AdminIcon from "../components/icons/AdminIcon.astro";

const { showNav = true } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ranq</title>
    <meta name="description" content="ranq — vote, rank and discuss with your friends." />
    <script is:inline>
      const t = localStorage.getItem("theme");
      if (t) document.documentElement.setAttribute("data-theme", t);
    </script>
    <script>
      import { startNotificationPolling } from "../scripts/notifications";
      startNotificationPolling();
    </script>
  </head>
  <body>
    <header>
      <Logo />
    </header>
    <main>
      <div class="scroll-wrapper">
        <slot />
        <p class="copyright">© {new Date().getFullYear()} ranq · <a href="/impressum">impressum</a> · <a href="/datenschutz">datenschutz</a></p>
      </div>
    </main>
    {showNav && <footer>
      <nav class="floating-nav">
        <a href="/start" aria-label="Home" aria-current={path === "/start" ? "page" : undefined}>
          <HomeIcon filled={path === "/start"} />
        </a>
        <a href="/search" aria-label="Search" aria-current={path === "/search" ? "page" : undefined}>
          <SearchIcon filled={path === "/search"} />
        </a>
        <a href="/create" aria-label="Add" aria-current={path === "/create" ? "page" : undefined}>
          <AddIcon filled={path === "/create"} />
        </a>
        <a href="/settings" aria-label="Settings" aria-current={path === "/settings" ? "page" : undefined}>
          <SettingsIcon filled={path === "/settings"} />
        </a>
        <a href="/admin" aria-label="Admin" id="admin-nav-link" style="display:none" aria-current={path === "/admin" ? "page" : undefined}>
          <AdminIcon filled={path === "/admin"} />
        </a>
      </nav>
    </footer>}
    <script is:inline>
      const isAdmin = document.cookie.split("; ").find(c => c.startsWith("isAdmin="))?.split("=")[1];
      if (isAdmin === "true") {
        document.getElementById("admin-nav-link").style.display = "";
      }
    </script>
  </body>
</html>
