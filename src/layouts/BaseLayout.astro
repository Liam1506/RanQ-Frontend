---
import "../styles/baseLayout.css";
import ThemeToggle from "../components/ThemeToggle.astro";
import Logo from "../components/Logo.astro";
import HomeIcon from "../components/icons/HomeIcon.astro";
import SearchIcon from "../components/icons/SearchIcon.astro";
import AddIcon from "../components/icons/AddIcon.astro";
import SettingsIcon from "../components/icons/SettingsIcon.astro";
import LogoutIcon from "../components/icons/LogoutIcon.astro";

const { showNav = true } = Astro.props;
const path = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ranq</title>
    <script is:inline>
      const t = localStorage.getItem("theme");
      if (t) document.documentElement.setAttribute("data-theme", t);
    </script>
  </head>
  <body>
    <header>
      <Logo />
      <ThemeToggle />
    </header>
    <main>
      <div class="scroll-wrapper">
        <slot />
      </div>
    </main>
    {showNav && <footer>
      <nav class="floating-nav">
        <a href="/start" aria-label="Home" aria-current={path === "/start" ? "page" : undefined}>
          <HomeIcon />
        </a>
        <a href="/search" aria-label="Search" aria-current={path === "/search" ? "page" : undefined}>
          <SearchIcon />
        </a>
        <a href="/create" aria-label="Add" aria-current={path === "/create" ? "page" : undefined}>
          <AddIcon />
        </a>
        <a href="/settings" aria-label="Settings" aria-current={path === "/settings" ? "page" : undefined}>
          <SettingsIcon />
        </a>
        <a href="/login" aria-label="Logout">
          <LogoutIcon />
        </a>
      </nav>
    </footer>}
  </body>
</html>
