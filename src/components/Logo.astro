---

<a href="/start" id="site-logo" aria-label="Home">
  <img id="logo-light" src="/ranQLightmode.svg" alt="ranq" />
  <img id="logo-dark" src="/ranQDarkmode.svg" alt="ranq" />
</a>

<style is:global>
  #site-logo {
    position: fixed;
    top: 0.25rem;
    left: 2rem;
    z-index: 100;
    display: flex;
    align-items: center;
  }

  #site-logo img {
    height: 5rem;
    width: 5rem;
    display: none;
  }

  /* light mode default */
  #logo-light {
    display: block;
  }
  #logo-dark {
    display: none;
  }

  [data-theme="dark"] #logo-light {
    display: none;
  }
  [data-theme="dark"] #logo-dark {
    display: block;
  }

  @media (prefers-color-scheme: dark) {
    #logo-light {
      display: none;
    }
    #logo-dark {
      display: block;
    }

    [data-theme="light"] #logo-light {
      display: block;
    }
    [data-theme="light"] #logo-dark {
      display: none;
    }
  }
</style>
