---

<a href="/start" id="site-logo" aria-label="Home">
  <img id="logo-light" src="/ranQLightmode.svg" alt="ranq" />
  <img id="logo-dark" src="/ranQDarkmode.svg" alt="ranq" />
</a>

<style is:global>
  #site-logo {
    position: fixed;
    top: 0.25rem;
    left: 2rem;
    z-index: 100;
    display: flex;
    align-items: center;
  }

  #site-logo img {
    height: 5rem;
    width: 5rem;
    display: none;
  }

  /* system mode default (light OS) */
  #site-logo #logo-light {
    display: block;
  }

  /* system mode + dark OS preference */
  @media (prefers-color-scheme: dark) {
    #site-logo #logo-light {
      display: none;
    }
    #site-logo #logo-dark {
      display: block;
    }
  }

  /* forced light */
  [data-theme="light"] #logo-light {
    display: block;
  }
  [data-theme="light"] #logo-dark {
    display: none;
  }

  /* forced dark */
  [data-theme="dark"] #logo-light {
    display: none;
  }
  [data-theme="dark"] #logo-dark {
    display: block;
  }
</style>
